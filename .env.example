# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Caffè 54 Menu"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Change this to a strong secret before deploying!
ADMIN_ACCESS_TOKEN=change-me-secure-token

# ─── Database ─────────────────────────────────────────────────────────────────
# "local" uses a JSON file in /data/.local-db.json (dev only)
# "d1"    uses Cloudflare D1 (production)
DATABASE_PROVIDER=local
DATABASE_URL=

# ─── Storage ──────────────────────────────────────────────────────────────────
# "local" saves to /public/uploads/ (dev only)
# "r2"    uses Cloudflare R2 (production)
STORAGE_PROVIDER=local

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── i18n ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LANGUAGE=pt
NEXT_PUBLIC_SUPPORTED_LANGUAGES=pt,en,es

# ─── Feature flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_FEEDBACK=true
NEXT_PUBLIC_ENABLE_RECOMMENDATIONS=true
NEXT_PUBLIC_ENABLE_ADMIN=true

# ─── Images ───────────────────────────────────────────────────────────────────
IMAGE_MAX_SIZE_MB=3
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60
