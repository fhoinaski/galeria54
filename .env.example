# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Caffè 54 Menu"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Troque por um segredo forte antes de fazer deploy!
ADMIN_ACCESS_TOKEN=change-me-secure-token

# ─── Database ─────────────────────────────────────────────────────────────────
# "local" → JSON em data/.local-db.json (dev, zero deps)
# "d1"    → Cloudflare D1 via binding caffe54_menu_db (produção)
DATABASE_PROVIDER=local
DATABASE_URL=

# ─── Storage ──────────────────────────────────────────────────────────────────
# "local" → /public/uploads/ (dev)
# "r2"    → Cloudflare R2 via binding caffe54_menu_images (produção)
# Acesso via CF binding — sem R2_ACCESS_KEY_ID nem R2_SECRET_ACCESS_KEY
STORAGE_PROVIDER=local
R2_BUCKET_NAME=caffe54-menu-images
R2_PUBLIC_URL=

# ─── i18n ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LANGUAGE=pt
NEXT_PUBLIC_SUPPORTED_LANGUAGES=pt,en,es

# ─── Feature flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_FEEDBACK=true
NEXT_PUBLIC_ENABLE_RECOMMENDATIONS=true
NEXT_PUBLIC_ENABLE_ADMIN=true

# ─── Images ───────────────────────────────────────────────────────────────────
IMAGE_MAX_SIZE_MB=3
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60
